// Schema Prisma pour l'ENT Mairie de Saint-Fortunat-sur-Eyrieux
//
// Reflète le modèle de données actuel (types.ts + people.ts) avec
// les adaptations nécessaires pour le stockage relationnel.
//
// Convention :
// - id : cuid() pour les nouveaux enregistrements
// - createdAt / updatedAt automatiques
// - timestamps en DateTime (était string ISO en localStorage)
// - Relations explicites avec cascade pour les suppressions cohérentes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Authentication (NextAuth.js / Auth.js v5) ─────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  hashedPassword String?  // pour Credentials provider
  mustChangePassword Boolean @default(false)  // force le changement à la 1ère connexion / après reset
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Lien avec le profil métier (Person)
  personId      String?   @unique
  person        Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)

  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

// Journal d'audit : trace des actions sensibles (accès, finances, RH…).
model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  actorId   String?  // Person.id (snapshot ; pas de FK pour survivre aux suppressions)
  actorName String
  action    String   // ex. 'facture.validate', 'person.create'
  entity    String   // ex. 'facture', 'person', 'leave'
  entityId  String?
  summary   String

  @@index([createdAt])
  @@map("audit_logs")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Référentiel métier ────────────────────────────────────────────

enum PersonRole {
  maire
  adjoint
  elu
  agent
}

enum AuthLevel {
  super_admin
  admin
  gestionnaire
  contributeur
  lecteur
}

model Person {
  id                       String     @id @default(cuid())
  prenom                   String
  nom                      String
  fullName                 String
  role                     PersonRole
  poste                    String
  email                    String     @unique
  phone                    String?
  color                    String
  photoUrl                 String?    // photo d'avatar (data URL base64, miniature ~128px) — optionnelle
  initials                 String
  authLevel                AuthLevel
  customPermissions        String[]   // tableau de Permission keys
  canSign                  Boolean    @default(false)
  signatureDomains         String[]   // tableau de SignatureDomain keys
  responsibleCommissions   String[]   // tableau de Commission ids (référent·e)
  commissions              String[]   // tableau de Commission ids (membre)
  hiddenModules            String[]   // clés de modules de nav masqués pour ce profil (cf. lib/modules)
  active                   Boolean    @default(true)
  startDate                DateTime?

  user           User?
  tasksValidated Task[]            @relation("TaskValidator")
  tasksCreated   Task[]            @relation("TaskCreator")
  taskComments   TaskComment[]
  employee       EmployeeRecord?
  leaveRequests  LeaveRequest[]    @relation("LeaveRequester")
  leaveDecisions LeaveRequest[]    @relation("LeaveDecider")
  missions       Mission[]
  pointages      Pointage[]
  pointageValidations Pointage[]   @relation("PointageValidator")
  facturesSubmitted   Facture[]    @relation("FactureSubmitter")
  facturesValidated   Facture[]    @relation("FactureValidator")
  facturesRejected    Facture[]    @relation("FactureRejecter")
  facturesPaid        Facture[]    @relation("FacturePayer")
  bulletins      BulletinPaie[]
  ecrituresCreated Ecriture[]      @relation("EcritureCreator")
  comptesRendus  CompteRendu[]     @relation("CompteRenduUploader")
  libraryFoldersCreated LibraryFolder[]
  libraryDocumentsUploaded LibraryDocument[]
  relancesEnvoyees    Relance[]         @relation("RelanceCreator")

  @@map("persons")
}

// ─── Commissions ───────────────────────────────────────────────────

model Commission {
  id          String    @id
  name        String
  color       String
  nextMeeting String
  meetings    Meeting[]

  @@map("commissions")
}

// ─── Réunions de commission ────────────────────────────────────────

model Meeting {
  id           String     @id @default(cuid())
  commissionId String
  commission   Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  date         DateTime
  heure        String?
  lieu         String?
  titre        String?
  notes        String?
  agenda       Json?      // [{ titre: string, rapporteurId?: string }] — ordre du jour
  createdAt    DateTime   @default(now())

  @@index([commissionId])
  @@map("meetings")
}

// ─── Délibérations (conseil municipal) ─────────────────────────────

model Deliberation {
  id             String             @id @default(cuid())
  numero         String
  objet          String
  date           DateTime
  statut         DeliberationStatut @default(a_venir)
  votePour       Int                @default(0)
  voteContre     Int                @default(0)
  voteAbstention Int                @default(0)
  commissionId   String?            // rattachement (conseil-municipal en pratique)
  notes          String?            @db.Text
  createdAt      DateTime           @default(now())

  @@index([commissionId])
  @@map("deliberations")
}

enum DeliberationStatut {
  a_venir
  adoptee
  rejetee
  reportee
}

// ─── Scénarios de simulation financière (what-if) ──────────────────

model Scenario {
  id          String   @id @default(cuid())
  nom         String
  description String?
  horizon     Int      @default(5)
  croissance  Float    @default(1.5)
  params      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("scenarios")
}

// ─── Tâches ────────────────────────────────────────────────────────

enum TaskPriority {
  urgent
  normal
  faible
}

enum TaskStatus {
  a_faire
  en_cours
  en_attente_validation
  termine
}

model Task {
  id            String       @id @default(cuid())
  label         String
  description   String?
  commissionIds String[]     @default([]) // références Commission.id (multi)
  assigneeIds   String[]     @default([]) // références Person.id — vide = non assignée
  validatorId  String?
  validator    Person?       @relation("TaskValidator", fields: [validatorId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    Person?       @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  dueDate      DateTime?
  priority     TaskPriority
  status       TaskStatus
  documents    Document[]
  comments     TaskComment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    Person   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@map("task_comments")
}

// ─── Documents (polymorphique simplifié) ───────────────────────────

// Une ressource attachée à plusieurs entités métier. Pour simplifier
// la migration depuis localStorage, on garde une relation explicite
// par entité plutôt qu'un polymorphisme. Le storage du contenu se
// fait soit dans `dataUrl` (legacy < 1 Mo) soit dans Supabase Storage.
model Document {
  id         String   @id @default(cuid())
  name       String
  size       Int
  type       String
  dataUrl    String?  @db.Text         // base64 pour les petits fichiers
  storageUrl String?                   // URL Supabase Storage pour les gros
  uploadedAt DateTime @default(now())

  // Relations optionnelles vers les entités
  taskId            String?
  task              Task?               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  factureId         String?
  facture           Facture?            @relation(fields: [factureId], references: [id], onDelete: Cascade)
  employeeId        String?
  employee          EmployeeRecord?     @relation(fields: [employeeId], references: [personId], onDelete: Cascade)
  leaveRequestId    String?
  leaveRequest      LeaveRequest?       @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  missionId         String?
  mission           Mission?            @relation(fields: [missionId], references: [id], onDelete: Cascade)
  bienId            String?
  bien              BienImmobilier?     @relation(fields: [bienId], references: [id], onDelete: Cascade)
  bailId            String?
  bail              Bail?               @relation(fields: [bailId], references: [id], onDelete: Cascade)
  subventionId      String?
  subvention        DemandeSubvention?  @relation(fields: [subventionId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ─── Finances : Factures, Fournisseurs ────────────────────────────

enum FactureStatut {
  a_soumettre
  en_attente_validation
  validee
  payee
  rejetee
}

model Fournisseur {
  id              String    @id @default(cuid())
  nom             String
  categorie       String
  siret           String?
  email           String?
  phone           String?
  numClient       String?
  posteParDefaut  String?
  delaiPaiement   Int?
  active          Boolean   @default(true)
  totalEngage     Decimal   @default(0) @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())

  factures Facture[]

  @@map("fournisseurs")
}

model Facture {
  id              String        @id @default(cuid())
  numero          String        @unique
  fournisseurId   String
  fournisseur     Fournisseur   @relation(fields: [fournisseurId], references: [id], onDelete: Restrict)
  montantTTC      Decimal       @db.Decimal(12, 2)
  posteCode       String
  dateFacture     DateTime
  dateEcheance    DateTime?
  statut          FactureStatut

  submittedById   String
  submittedBy     Person        @relation("FactureSubmitter", fields: [submittedById], references: [id], onDelete: Restrict)
  submittedAt     DateTime
  validatedById   String?
  validatedBy     Person?       @relation("FactureValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  validatedAt     DateTime?
  rejectedById    String?
  rejectedBy      Person?       @relation("FactureRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt      DateTime?
  rejectionReason String?       @db.Text

  paidById        String?
  paidBy          Person?       @relation("FacturePayer", fields: [paidById], references: [id], onDelete: SetNull)
  paidAt          DateTime?
  datePaiement    DateTime?

  documents       Document[]
  notes           String?       @db.Text
  ecritures       Ecriture[]
  createdAt       DateTime      @default(now())

  @@map("factures")
}

// ─── Plan comptable M14 + écritures ───────────────────────────────

model CompteM14 {
  code                  String    @id
  label                 String
  chapitreCode          String
  section               String    // 'fonctionnement' | 'investissement'
  sens                  String    // 'D' | 'R'
  budgetAlloue          Decimal   @db.Decimal(12, 2)
  consommationInitiale  Decimal   @db.Decimal(12, 2)

  @@map("comptes_m14")
}

model Ecriture {
  id          String        @id @default(cuid())
  numero      Int
  exercice    Int
  date        DateTime
  journal     String        // 'AC' | 'BQ' | 'OD' | 'AN' | 'CA'
  libelle     String
  pieceRef    String?
  factureId   String?
  facture     Facture?      @relation(fields: [factureId], references: [id], onDelete: Cascade)
  quittanceId String?
  quittance   Quittance?    @relation(fields: [quittanceId], references: [id], onDelete: Cascade)
  subventionId String?
  subvention  DemandeSubvention? @relation(fields: [subventionId], references: [id], onDelete: Cascade)
  lignes      LigneEcriture[]
  createdAt   DateTime      @default(now())
  createdById String
  createdBy   Person        @relation("EcritureCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([exercice, numero])
  @@map("ecritures")
}

model LigneEcriture {
  id         String   @id @default(cuid())
  ecritureId String
  ecriture   Ecriture @relation(fields: [ecritureId], references: [id], onDelete: Cascade)
  compteCode String
  libelle    String?
  debit      Decimal  @db.Decimal(12, 2) @default(0)
  credit     Decimal  @db.Decimal(12, 2) @default(0)

  @@map("lignes_ecriture")
}

model ExerciceHistorique {
  id                String   @id @default(cuid())
  exercice          Int      @unique
  population        Int
  rrf               Decimal  @db.Decimal(12, 2)
  drf               Decimal  @db.Decimal(12, 2)
  charges011        Decimal  @db.Decimal(12, 2)
  charges012        Decimal  @db.Decimal(12, 2)
  charges65         Decimal  @db.Decimal(12, 2)
  charges66         Decimal  @db.Decimal(12, 2)
  produits73        Decimal  @db.Decimal(12, 2)
  produits74        Decimal  @db.Decimal(12, 2)
  produits7411      Decimal  @db.Decimal(12, 2)
  produits7311      Decimal  @db.Decimal(12, 2)
  depEquipement     Decimal  @db.Decimal(12, 2)
  recettesInvest    Decimal  @db.Decimal(12, 2)
  encoursDette      Decimal  @db.Decimal(12, 2)
  capitalRembourse  Decimal  @db.Decimal(12, 2)
  notes             String?  @db.Text
  importedAt        DateTime @default(now())

  @@map("exercices_historique")
}

// ─── RH ────────────────────────────────────────────────────────────

enum TypeContrat {
  titulaire
  contractuel_cdi
  contractuel_cdd
  stagiaire
  apprenti
}

model EmployeeRecord {
  personId             String   @id
  person               Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  numAgent             String   @unique
  contrat              TypeContrat
  cadre                String?  // 'A' | 'B' | 'C'
  grade                String?
  echelon              Int?
  tempsTravailHeures   Decimal  @db.Decimal(4, 1)
  dateEmbauche         DateTime
  dateFinContrat       DateTime?
  salaireBrut          Decimal  @db.Decimal(10, 2)
  primes               Decimal? @db.Decimal(10, 2)
  ifse                 Decimal? @db.Decimal(10, 2)
  congesAnnuelsAcquis  Decimal  @db.Decimal(5, 2)
  congesAnnuelsPris    Decimal  @db.Decimal(5, 2)
  rttAcquis            Decimal  @db.Decimal(5, 2)
  rttPris              Decimal  @db.Decimal(5, 2)
  joursMaladie         Decimal  @db.Decimal(5, 2)
  documents            Document[]
  notes                String?  @db.Text
  bulletins            BulletinPaie[]
  createdAt            DateTime @default(now())

  @@map("employee_records")
}

enum LeaveStatut {
  en_attente
  approuvee
  refusee
  annulee
}

model LeaveRequest {
  id              String       @id @default(cuid())
  personId        String
  person          Person       @relation("LeaveRequester", fields: [personId], references: [id], onDelete: Cascade)
  type            String       // 'Congés annuels' | 'RTT' | etc.
  dateDebut       DateTime
  dateFin         DateTime
  nbJoursOuvres   Decimal      @db.Decimal(5, 2)
  motif           String?      @db.Text
  statut          LeaveStatut
  submittedAt     DateTime
  decidedById     String?
  decidedBy       Person?      @relation("LeaveDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt       DateTime?
  decisionMotif   String?      @db.Text
  documents       Document[]
  createdAt       DateTime     @default(now())

  @@map("leave_requests")
}

model Mission {
  id          String   @id @default(cuid())
  personId    String
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  label       String
  description String?  @db.Text
  dateDebut   DateTime
  dateFin     DateTime?
  lieu        String?
  documents   Document[]
  createdAt   DateTime @default(now())

  @@map("missions")
}

// ─── Pointage ──────────────────────────────────────────────────────

enum PointageType {
  entree
  sortie
  pause_debut
  pause_fin
}

enum PointageValidationStatut {
  en_attente
  approuvee
  refusee
}

model Pointage {
  id                 String                     @id @default(cuid())
  personId           String
  person             Person                     @relation(fields: [personId], references: [id], onDelete: Cascade)
  type               PointageType
  timestamp          DateTime
  manuel             Boolean                    @default(false)
  motif              String?                    @db.Text
  validationStatut   PointageValidationStatut?
  validateurId       String?
  validateur         Person?                    @relation("PointageValidator", fields: [validateurId], references: [id], onDelete: SetNull)
  validatedAt        DateTime?
  validationMotif    String?                    @db.Text
  createdAt          DateTime                   @default(now())
  createdById        String

  @@map("pointages")
}

// ─── Bulletins de paie ─────────────────────────────────────────────

model BulletinPaie {
  id                    String         @id @default(cuid())
  personId              String
  person                Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  employeeId            String
  employee              EmployeeRecord @relation(fields: [employeeId], references: [personId], onDelete: Cascade)
  numero                String         @unique
  mois                  String         // 'YYYY-MM'
  snapshot              Json           // snapshot complet de l'agent au moment du bulletin
  lignes                Json           // tableau de lignes (rémunérations / cotisations)
  brutTotal             Decimal        @db.Decimal(10, 2)
  cotisationsSalariales Decimal        @db.Decimal(10, 2)
  cotisationsPatronales Decimal        @db.Decimal(10, 2)
  netImposable          Decimal        @db.Decimal(10, 2)
  netAPayer             Decimal        @db.Decimal(10, 2)
  coutEmployeur         Decimal        @db.Decimal(10, 2)
  statut                String         // 'Émis' | 'Distribué' | 'Annulé'
  emisAt                DateTime
  createdAt             DateTime       @default(now())

  @@map("bulletins_paie")
}

// ─── Parc immobilier ───────────────────────────────────────────────

model BienImmobilier {
  id                 String   @id @default(cuid())
  reference          String   @unique
  nom                String
  type               String
  adresse            String
  surface            Decimal  @db.Decimal(8, 2)
  pieces             Int?
  loyerMensuel       Decimal  @db.Decimal(10, 2)
  chargesMensuelles  Decimal  @db.Decimal(10, 2)
  notes              String?  @db.Text
  documents          Document[]
  active             Boolean  @default(true)
  baux               Bail[]
  createdAt          DateTime @default(now())

  @@map("biens_immobiliers")
}

model Locataire {
  id                 String   @id @default(cuid())
  prenom             String
  nom                String
  fullName           String
  email              String?
  phone              String?
  adresseFacturation String?
  notes              String?  @db.Text
  baux               Bail[]
  createdAt          DateTime @default(now())

  @@map("locataires")
}

enum StatutBail {
  en_cours
  preavis
  termine
}

model Bail {
  id                       String         @id @default(cuid())
  bienId                   String
  bien                     BienImmobilier @relation(fields: [bienId], references: [id], onDelete: Restrict)
  locataireId              String
  locataire                Locataire      @relation(fields: [locataireId], references: [id], onDelete: Restrict)
  dateDebut                DateTime
  dateFin                  DateTime?
  loyerMensuel             Decimal        @db.Decimal(10, 2)
  chargesMensuelles        Decimal        @db.Decimal(10, 2)
  chargesOrduresMensuelles Decimal        @db.Decimal(10, 2) @default(0)
  chargesGazMensuelles     Decimal        @db.Decimal(10, 2) @default(0)
  chargesAutresMensuelles  Decimal        @db.Decimal(10, 2) @default(0)
  depotGarantie            Decimal        @db.Decimal(10, 2)
  statut                   StatutBail
  notes                    String?        @db.Text
  documents                Document[]
  quittances               Quittance[]
  createdAt                DateTime       @default(now())

  @@map("baux")
}

enum StatutQuittance {
  a_emettre
  emise
  payee
  impayee
  relancee
}

model Quittance {
  id              String          @id @default(cuid())
  bailId          String
  bail            Bail            @relation(fields: [bailId], references: [id], onDelete: Cascade)
  mois            String          // 'YYYY-MM'
  numero          String          @unique
  loyerHC         Decimal         @db.Decimal(10, 2)
  charges         Decimal         @db.Decimal(10, 2)
  chargesOrdures  Decimal         @db.Decimal(10, 2) @default(0)
  chargesGaz      Decimal         @db.Decimal(10, 2) @default(0)
  chargesAutres   Decimal         @db.Decimal(10, 2) @default(0)
  total           Decimal         @db.Decimal(10, 2)
  statut          StatutQuittance
  emiseAt         DateTime?
  payeeAt         DateTime?
  modeReglement   String?
  notes           String?         @db.Text
  ecritures       Ecriture[]
  relances        Relance[]
  createdAt       DateTime        @default(now())

  @@map("quittances")
}

// Historique des relances de paiement sur une quittance impayée.
// Une quittance peut avoir N relances. Le résultat (paiement, refus, etc.)
// est saisi a posteriori pour traçabilité administrative.
model Relance {
  id          String    @id @default(cuid())
  quittanceId String
  quittance   Quittance @relation(fields: [quittanceId], references: [id], onDelete: Cascade)
  date        DateTime
  canal       String    // 'Courrier' | 'Email' | 'SMS' | 'Téléphone' | 'En personne' | 'Autre'
  contenu     String?   @db.Text
  resultat    String?   // 'Sans réponse' | 'Engagement de paiement' | 'Payée' | 'Refus' | 'Autre'
  createdById String
  createdBy   Person    @relation("RelanceCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())

  @@map("relances")
}

// ─── Subventions ───────────────────────────────────────────────────

model DemandeSubvention {
  id                       String   @id @default(cuid())
  reference                String   @unique
  intitule                 String
  description              String?  @db.Text
  source                   String
  organisme                String
  contactNom               String?
  contactEmail             String?
  montantProjet            Decimal  @db.Decimal(12, 2)
  montantDemande           Decimal  @db.Decimal(12, 2)
  montantAccorde           Decimal? @db.Decimal(12, 2)
  montantVerse             Decimal? @db.Decimal(12, 2)
  dateDepot                DateTime?
  dateDecision             DateTime?
  datePrevisionVersement   DateTime?
  statut                   String
  motifRefus               String?  @db.Text
  imputationCompte         String?
  documents                Document[]
  ecritures                Ecriture[]
  notes                    String?  @db.Text
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("demandes_subventions")
}

// ─── Projets d'investissement ──────────────────────────────────────

model Projet {
  id              String              @id @default(cuid())
  nom             String
  description     String?             @db.Text
  coutTotal       Decimal             @db.Decimal(12, 2)
  coutHT          Decimal?            @db.Decimal(12, 2)
  imputationCompte String
  anneeDebut      Int
  anneesEtalement Int
  tauxFCTVA       Decimal?            @db.Decimal(6, 3)
  notes           String?             @db.Text
  financements    FinancementProjet[]
  createdAt       DateTime            @default(now())

  @@map("projets")
}

model FinancementProjet {
  id              String   @id @default(cuid())
  projetId        String
  projet          Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)
  source          String
  organisme       String?
  montant         Decimal  @db.Decimal(12, 2)
  dureeAnnees     Int?
  tauxInteret     Decimal? @db.Decimal(6, 3)
  anneeVersement  Int?
  certitude       String?
  subventionId    String?

  @@map("financements_projet")
}

// ─── Comptes rendus ────────────────────────────────────────────────

model CompteRendu {
  id            String        @id @default(cuid())
  filename      String
  commissionId  String?
  meetingDate   DateTime?
  importedAt    DateTime      @default(now())
  pdfDataUrl    String?       @db.Text
  pdfStorageUrl String?
  uploadedById  String?
  uploadedBy    Person?       @relation("CompteRenduUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  taskIds       String[]      // tâches créées suite à validation

  @@map("comptes_rendus")
}

// ─── Bibliothèque (GED arborescente, stockage Supabase Storage) ────

model LibraryFolder {
  id          String            @id @default(cuid())
  name        String
  parentId    String?
  parent      LibraryFolder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    LibraryFolder[]   @relation("FolderTree")
  documents   LibraryDocument[]
  createdById String
  createdBy   Person            @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([parentId, name])
  @@map("library_folders")
}

model LibraryDocument {
  id           String        @id @default(cuid())
  folderId     String
  folder       LibraryFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  name         String
  filename     String
  mimeType     String
  size         Int
  storagePath  String        // chemin dans le bucket Supabase Storage
  uploadedById String
  uploadedBy   Person        @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  uploadedAt   DateTime      @default(now())

  @@map("library_documents")
}
