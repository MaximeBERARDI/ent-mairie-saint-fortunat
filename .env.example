# ─── Base de données Supabase (Postgres) ───────────────────────────
# Récupère ces deux URLs depuis Supabase :
#   Settings → Database → Connection string
#
# DATABASE_URL  : connexion pooled (port 6543), utilisée par l'app en runtime
# DIRECT_URL    : connexion directe (port 5432), utilisée par les migrations Prisma
DATABASE_URL="postgresql://postgres.<project>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project>:<password>@<region>.pooler.supabase.com:5432/postgres"

# ─── NextAuth (Auth.js v5) ──────────────────────────────────────────
# AUTH_SECRET : chaîne aléatoire de 32+ caractères. Génère avec :
#   openssl rand -base64 32
# NEXTAUTH_URL : URL de prod (Vercel l'injecte automatiquement)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Anthropic API (existant, pour /comptes-rendus extraction IA) ───
ANTHROPIC_API_KEY="sk-ant-..."
